@baseUrl = http://localhost:8080
@accessToken = replace-with-access-token
@refreshToken = replace-with-refresh-token
@uploadUrl = paste-presigned-upload-url-here
@uploadFile = ./amazon-q-detectors-main.zip
@accountId = 564061926474
@scanId = scan-local-001

### Health
GET {{baseUrl}}/actuator/health

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "username": "qca-admin",
  "password": "local-dev-password"
}

### Refresh tokens
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Create scan
POST {{baseUrl}}/api/create-scan
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "scanId": "{{scanId}}",
  "accountId": "{{accountId}}",
  "repoFullName": "devashishrane/qca",
  "prNumber": 42,
  "headSha": "abc123def4567890",
  "useCase": "github-pr-scan",
  "service": "fes"
}

### Upload scan input using the uploadUrl returned by create-scan
PUT {{uploadUrl}}
Content-Type: application/octet-stream

< {{uploadFile}}

### Start scan
POST {{baseUrl}}/api/start-scan
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "scanId": "{{scanId}}"
}

### List scans by account
GET {{baseUrl}}/api/accounts/{{accountId}}/scans?limit=50

### Get scan status
GET {{baseUrl}}/api/scans/{{scanId}}/status

### Get scan findings
### If only one engine succeeded, findings will return the successful engine output only.
GET {{baseUrl}}/api/scans/{{scanId}}/findings
