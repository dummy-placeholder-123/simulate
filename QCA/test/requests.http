@baseUrl = http://localhost:8080
@apiKey = local-dev-api-key
@uploadUrl = paste-presigned-upload-url-here
@uploadFile = ./amazon-q-detectors-main.zip

### Create GitHub PR scan
POST {{baseUrl}}/api/create-scan
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "scanId": "scan-local-001",
  "accountId": "564061926474",
  "repoFullName": "devashishrane/qca",
  "prNumber": 42,
  "headSha": "abc123def4567890",
  "useCase": "github-pr-scan",
  "service": "fes"
}

### Upload scan input to presigned URL
PUT {{uploadUrl}}
Content-Type: application/octet-stream

< {{uploadFile}}

### Start scan processing
POST {{baseUrl}}/api/start-scan
Content-Type: application/json
X-API-Key: {{apiKey}}

{
  "scanId": "scan-local-001"
}

### List scans by account
GET {{baseUrl}}/api/accounts/564061926474/scans?limit=50

### Get scan status
GET {{baseUrl}}/api/scans/scan-local-001/status

### Get scan findings
GET {{baseUrl}}/api/scans/scan-local-001/findings
